{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Review Ticket",
  "description": "记忆草案审批记录",
  "type": "object",
  "required": ["id", "mem_id", "submitted_at", "decision"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^REV-\\d{8}-[a-z0-9]+$"
    },
    "mem_id": {
      "type": "string"
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time"
    },
    "decision": {
      "type": "string",
      "enum": ["approved", "revise", "rejected", "hold"]
    },
    "reviewer": {
      "type": "string"
    },
    "comment": {
      "type": "string"
    },
    "decided_at": {
      "type": "string",
      "format": "date-time"
    },
    "changes_requested": {
      "type": "string"
    }
  }
}
